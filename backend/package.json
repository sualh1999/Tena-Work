{
  "name": "tenawork-backend",
  "version": "1.0.0",
  "description": "TenaWork Backend API - AI-Powered Healthcare Job Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate:up": "node src/db/migrate.js up",
    "migrate:down": "node src/db/migrate.js down",
    "migrate:create": "node src/db/migrate.js create",
    "db:seed": "node src/db/seed.js",
    "db:setup": "node scripts/setup-db.js",
    "generate:jwt": "node scripts/setup-db.js --generate-jwt",
    "setup:ai": "node scripts/setup-ai-integration.js"
  },
  "keywords": ["healthcare", "jobs", "ai", "matching"],
  "author": "Nile Technology Solutions",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
